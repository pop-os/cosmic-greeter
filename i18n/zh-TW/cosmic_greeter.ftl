cancel = 取消
keyboard-layout = 鍵盤配置
restart = 重新啟動
restart-now = 立即重新啟動？
restart-timeout =
    系統將自動重新啟動 
    { $seconds ->
        [0] 現在。
        [1] 於 1 秒內。
       *[other] 於 { $seconds } 秒內。
    }
session = 工作階段
shutdown = 關機
shutdown-now = 立即關閉電源？
shutdown-timeout =
    系統將會自動關機 
    { $seconds ->
        [0] 立即。
        [1] 於 1 秒內。
       *[other] 於 { $seconds } 秒內。
    }
suspend = 休眠
user = 使用者
accessibility = 無障礙功能
    .screen-reader = 螢幕閱讀器
    .magnifier = 放大鏡
    .high-contrast = 高對比
    .invert-colors = 反轉顏色
authenticating = 驗證中...
caps-lock = Caps Lock 已啟用。
enter-user = 手動輸入名稱...
type-username = 使用者名稱：
auth-error-default = 驗證失敗。請再試一次。
auth-error-credentials = 密碼錯誤。請檢查您的鍵盤配置並再試一次。
auth-error-denied = 拒絕存取。
auth-error-maxtries = 身分驗證失敗次數過多。
auth-error-account = 帳號無法使用或已停用。
