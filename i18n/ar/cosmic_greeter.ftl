accessibility = الإتاحة
    .screen-reader = قارئ الشاشة
    .magnifier = المكبر
    .high-contrast = تباين عالٍ
    .invert-colors = عكس الألوان
cancel = ألغِ
caps-lock = مفتاح Caps Lock نشط.
enter-user = أدخل الاسم يدويًا...
type-username = اسم المستخدم:
keyboard-layout = تخطيط لوحة المفاتيح
restart = أعد التشغيل
restart-now = إعادة التشغيل الآن؟
restart-timeout =
    سيتم إعادة تشغيل النظام تلقائيًا في غضون
    { $seconds ->
        [0] الآن.
        [1] في ثانية.
       *[other] في { $seconds } ثانية.
    }
session = الجلسة
shutdown = أطفئ
shutdown-now = أطفئ الآن؟
shutdown-timeout =
    سيتم إيقاف تشغيل النظام تلقائيًا في
    { $seconds ->
        [0] الآن.
        [1] في ثانية.
       *[other] في { $seconds } ثانية.
    }
suspend = علِّق
user = المستخدم
authenticating = يستوثّق...
auth-error-maxtries = عدد كبير جدًا من محاولات الاستيثاق الفاشلة.
auth-error-credentials = كلمة السر غير صحيحة. يُرجى التحقق من تخطيط لوحة المفاتيح والمحاولة مرة أخرى.
auth-error-denied = رُفض الوصول.
auth-error-account = الحساب غير متاح أو مُعطّل.
