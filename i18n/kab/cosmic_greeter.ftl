cancel = Sefsex
restart-timeout =
    Anagraw ad yales tanekra s wudem awurman
    { $seconds ->
        [0] tura.
        [1] deg 1 n tasint.
       *[other] deg { $seconds } n tsinin.
    }
shutdown-timeout =
    Ad yexsi unagraw s wudem awurman
    { $seconds ->
        [0] tura.
        [1] deg 1 n tasint.
       *[other] deg { $seconds } n tasinin.
    }
